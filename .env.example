# Generic LLM configuration
# You can connect the model provider you want, for example Anthropic, OpenAI, or Gemini.
# Recommended format for LLM_MODEL_NAME: provider/model-name
# Examples:
# LLM_MODEL_NAME=openai/gpt-4o-mini
# LLM_MODEL_NAME=anthropic/claude-3-7-sonnet-latest
# LLM_MODEL_NAME=gemini/gemini-2.0-flash
LLM_PROVIDER=
LLM_MODEL_NAME=provider/model-name
LLM_API_KEY=your_api_key
# Optional: use this when the provider exposes an OpenAI-compatible base URL.
LLM_BASE_URL=
